{
  "name": "adk-qa",
  "version": "1.0.0",
  "description": "Multi-agent QA automation tool built on Google ADK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "bun src/index.ts",
    "test:auto": "bun src/index.ts auto --test-dir ./tests",
    "test:auto:local": "HEADLESS=false bun src/index.ts auto --test-dir ./tests",
    "eval": "bun src/evals/index.ts",
    "dev": "npx adk web",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "@google/genai": "^1.41.0",
    "commander": "^14.0.3",
    "glob": "^13.0.2",
    "puppeteer": "^22.15.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@google/adk-devtools": "^0.3.0",
    "@types/node": "^20.19.33",
    "@types/puppeteer": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
