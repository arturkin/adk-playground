{
  "name": "adk-qa",
  "version": "1.0.0",
  "description": "Multi-agent QA automation tool built on Google ADK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "run": "bun src/index.ts",
    "test:auto": "bun src/index.ts auto --test-dir ./tests",
    "test:auto:local": "HEADLESS=false bun src/index.ts auto --test-dir ./tests",
    "eval": "bun src/evals/index.ts",
    "dev": "npx adk web",
    "build": "tsc",
    "start": "node src/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/adk": "^0.5.0",
    "@google/genai": "^1.46.0",
    "commander": "14.0.3",
    "glob": "13.0.6",
    "puppeteer": "^24.39.1",
    "winston": "3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@google/adk-devtools": "^0.5.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/bun": "^1.3.10",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
